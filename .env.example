# ===========================================
# Complia Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Django Core
SECRET_KEY=your-secret-key-here-generate-with-django
DEBUG=True

# Database (leave empty for SQLite in local dev)
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# Allowed Hosts (comma-separated, no spaces)
# Example: complia-backend.onrender.com,api.complia.in
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS Allowed Origins (comma-separated, full URLs)
# Example: https://complia.in,https://www.complia.in
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Sentry Error Monitoring (leave empty to disable)
SENTRY_DSN=
