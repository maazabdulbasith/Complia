# ==============================
# Core Django
# ==============================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=True

# Comma-separated hostnames (no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated full origins with scheme
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# PostgreSQL in production. Leave empty for local SQLite fallback.
DATABASE_URL=

# Force DB SSL in production (`true`) if your provider requires it.
DB_SSL_REQUIRE=

# Optional hardening override when DEBUG=False
SECURE_HSTS_SECONDS=31536000

# ==============================
# Auth / Social
# ==============================
SITE_ID=1
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SUPERADMIN_EMAILS=
PARSER_BETA_EMAILS=
PARSER_PRIVATE_BETA_ENABLED=false
PARSER_REVIEW_THRESHOLD=0.75
PARSER_EPHEMERAL_TTL_HOURS=1
PARSER_MAX_UPLOAD_MB=10
ASSISTED_OFFER_ENABLED=true
ASSISTED_OFFER_DEFAULT_KEY=assisted_response_pack_v1
ASSISTED_OFFER_TARGET_SEVERITY=high

# ==============================
# Monitoring
# ==============================
SENTRY_DSN=
PUBLIC_SITE_URL=

# ==============================
# Frontend Build Variables
# ==============================
VITE_API_URL=http://127.0.0.1:8001/api/v1
VITE_SITE_URL=http://127.0.0.1:5173
VITE_GOOGLE_CLIENT_ID=
VITE_ENABLE_ANALYTICS=false

# ==============================
# Optional seed admin for setup_data.py
# ==============================
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
